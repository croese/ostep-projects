{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with Clang",
            "type": "shell",
            "command": "clang",
            "args": [
                "-std=c11",
                "reverse.c",
                "-o",
                "reverse",
                "--debug",
                "-Wall",
                "-Werror"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}